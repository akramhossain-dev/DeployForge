generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String?   @unique
  username      String?   @unique
  passwordHash  String?
  name          String?
  avatarUrl     String?
  githubId      String?   @unique
  githubUsername String?
  githubAvatar String?
  githubAccessToken String?
  googleId      String?   @unique
  googleEmail   String?
  googleAvatar  String?
  isVerified    Boolean   @default(false)
  role          String    @default("USER") // legacy user role; admin auth uses AdminUser
  status        String    @default("ACTIVE") // ACTIVE | SUSPENDED
  provider      String    @default("email") // "email" | "github" | "google"
  authProvider  String    @default("local") // "local" | "github" | "google"
  sessions      Session[]
  userSessions  UserSession[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  notificationPreferences NotificationPreference?
  auditLogs     AuditLog[]
  vps           VPS[]
  projects      Project[]
  githubAccount GitHubAccount?
  terminalSessions TerminalSession[]
  deployments   Deployment[]
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AdminUser {
  id            String          @id @default(uuid())
  email         String          @unique
  passwordHash  String
  role          String          // SUPER_ADMIN | ADMIN | MODERATOR
  createdById   String?
  createdBy     AdminUser?      @relation("AdminCreatedUsers", fields: [createdById], references: [id])
  createdAdmins AdminUser[]     @relation("AdminCreatedUsers")
  sessions      AdminSession[]
  activities    AdminActivity[]
  lastLoginAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([role])
  @@index([createdById])
}

model AdminSession {
  id           String    @id @default(uuid())
  adminId      String
  admin        AdminUser @relation(fields: [adminId], references: [id])
  tokenHash    String    @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([adminId])
  @@index([expiresAt])
}

model AdminActivity {
  id           String    @id @default(uuid())
  adminId      String
  admin        AdminUser @relation(fields: [adminId], references: [id])
  action       String
  targetUserId String?
  targetRole   String?
  targetType   String?
  targetId     String?
  ipAddress    String?
  timestamp    DateTime  @default(now())
  createdAt    DateTime  @default(now())

  @@index([adminId])
  @@index([targetUserId])
  @@index([timestamp])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  refreshToken String   @unique // Hashed
  authProvider  String   @default("local") // "local" | "github" | "google"
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   // Hashed OTP
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([email])
}

model GitHubAccount {
  id           String       @id @default(uuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id])
  githubId     String       @unique
  accessToken  String       // Encrypted
  username     String
  email        String?
  avatarUrl    String?
  repositories Repository[]
  connectedAt  DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Repository {
  id              String       @id @default(uuid())
  githubAccountId String
  githubAccount   GitHubAccount @relation(fields: [githubAccountId], references: [id])
  repoId          String       @unique // GitHub's internal ID
  name            String
  fullName        String
  description     String?
  private         Boolean      @default(false)
  defaultBranch   String       @default("main")
  cloneUrl        String?      // Optional encrypted
  webhookId       String?
  updatedAt       DateTime     @updatedAt
  createdAt       DateTime     @default(now())
}

model TerminalSession {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  vpsId        String
  vps          VPS        @relation(fields: [vpsId], references: [id])
  sessionId    String     @unique
  status       String     @default("ACTIVE") // ACTIVE, CLOSED, FAILED
  logs         TerminalCommandLog[]
  startedAt    DateTime   @default(now())
  endedAt      DateTime?

  @@index([userId])
  @@index([vpsId])
}

model TerminalCommandLog {
  id           String          @id @default(uuid())
  sessionId    String
  session      TerminalSession @relation(fields: [sessionId], references: [id])
  command      String?
  output       String?
  timestamp    DateTime        @default(now())

  @@index([sessionId])
}

model WebhookEvent {
  id           String   @id @default(uuid())
  repoId       String
  event        String   // e.g., "push"
  payload      String   // JSON string
  status       String   @default("PENDING") // PENDING, PROCESSED, FAILED
  error        String?
  createdAt    DateTime @default(now())

  @@index([repoId])
}

model VPS {
  id                   String       @id @default(uuid())
  userId               String
  user                 User         @relation(fields: [userId], references: [id])
  name                 String
  ipAddress            String
  port                 Int          @default(22)
  username             String       @default("root")
  authType             String       @default("key") // "key" | "password"
  encryptedPrivateKey  String?      // Encrypted AES-256-GCM
  encryptedPassword    String?      // Encrypted AES-256-GCM
  status               String       @default("inactive") // "active" | "inactive" | "failed"
  lastCheckedAt        DateTime?
  deployments          Deployment[]
  healthRecords        VPSHealth[]
  terminalSessions     TerminalSession[]
  domains              Domain[]
  systemMetrics        SystemMetrics[]
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([userId])
}

model VPSHealth {
  id              String   @id @default(cuid())
  vpsId           String
  vps             VPS      @relation(fields: [vpsId], references: [id])
  cpuUsage        Float
  memoryUsage     Float
  diskUsage       Float
  uptime          Int
  dockerInstalled Boolean
  nginxInstalled  Boolean
  checkedAt       DateTime @default(now())

  @@index([vpsId])
}

model Project {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  name          String
  repositoryUrl String
  branch        String       @default("main")
  framework     String?
  deployments   Deployment[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId])
}

model Deployment {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])
  vpsId         String
  vps           VPS      @relation(fields: [vpsId], references: [id])
  name          String?  // Deployment name/label
  status        String   @default("PENDING") // PENDING, BUILDING, RUNNING, FAILED, STOPPED
  framework     String?
  type          String   @default("SERVER") // STATIC | SERVER | FULLSTACK
  port          Int?
  buildCommand  String?
  startCommand  String?
  env           String?  // Encrypted JSON
  containerId   String?
  sourceType    String   @default("github") // github | upload
  repoUrl       String?
  branch        String?
  uploadPath    String?
  commitHash    String?
  commitMessage String?
  lastStableVersion String?
  domain        String?
  hostType      String   @default("ip") // ip | domain
  mode          String   @default("production") // production | sandbox
  logs          Log[]
  deploymentLogs DeploymentLog[]
  history       DeploymentHistory[]
  sandbox       DeploymentSandbox?
  domains       Domain[]
  jobs          DeploymentJob[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([projectId])
  @@index([vpsId])
  @@index([sourceType])
  @@index([type])
  @@index([domain])
  @@index([hostType])
  @@index([mode])
}

model DeploymentJob {
  id           String     @id @default(uuid())
  deploymentId String
  deployment   Deployment @relation(fields: [deploymentId], references: [id])
  status       String     @default("QUEUED") // QUEUED, RUNNING, SUCCESS, FAILED
  retryCount   Int        @default(0)
  lastError    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([deploymentId])
}

model Domain {
  id               String     @id @default(uuid())
  deploymentId     String
  deployment       Deployment @relation(fields: [deploymentId], references: [id])
  vpsId            String
  vps              VPS        @relation(fields: [vpsId], references: [id])
  domainName       String     @unique
  status           String     @default("PENDING") // pending | active | failed
  sslStatus        String     @default("NONE")    // NONE | ISSUED | EXPIRED | FAILED
  nginxConfigPath  String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([deploymentId])
  @@index([vpsId])
}

model DeploymentSandbox {
  id            String     @id @default(uuid())
  deploymentId  String     @unique
  deployment    Deployment @relation(fields: [deploymentId], references: [id])
  score         Int
  status        String     // approved | warning | rejected
  issues        String[]   // Array of strings
  estimatedCPU  Float
  estimatedRAM  Float
  estimatedDisk Float
  createdAt     DateTime   @default(now())
}

model DeploymentHistory {
  id            String     @id @default(uuid())
  deploymentId  String
  deployment    Deployment @relation(fields: [deploymentId], references: [id])
  version       String     // Commit hash or timestamp
  containerId   String?
  imageTag      String?
  status        String
  env           String?    // Encrypted JSON snapshot
  createdAt     DateTime   @default(now())

  @@index([deploymentId])
}

model SystemMetrics {
  id               String   @id @default(uuid())
  vpsId            String
  vps              VPS      @relation(fields: [vpsId], references: [id])
  cpuUsage         Float
  memoryUsage      Float
  diskUsage        Float
  activeContainers Int
  timestamp        DateTime @default(now())

  @@index([vpsId])
}

model DeploymentLog {
  id           String     @id @default(uuid())
  deploymentId String
  deployment   Deployment @relation(fields: [deploymentId], references: [id])
  type         String     // build | runtime | error | system
  level        String     @default("info") // info | warn | error
  message      String
  createdAt    DateTime   @default(now())

  @@index([deploymentId])
}

model Log {
  id           String     @id @default(cuid())
  deploymentId String
  deployment   Deployment @relation(fields: [deploymentId], references: [id])
  content      String
  type         String     @default("INFO") // INFO, ERROR, DEBUG
  createdAt    DateTime   @default(now())
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("new") // new | read | resolved
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique // Hashed
  userAgent    String?
  device       String?
  browser      String?
  os           String?
  ipAddress    String?
  lastActivity DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique // Hashed
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique // Hashed
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model NotificationPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deployNotifications Boolean  @default(true)
  buildNotifications  Boolean  @default(true)
  domainNotifications Boolean  @default(true)
  sslNotifications    Boolean  @default(true)
  securityAlerts      Boolean  @default(true)
  productUpdates      Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // Event Type: LOGIN_SUCCESS, LOGIN_FAILURE, etc.
  details   String
  ipAddress String?
  device    String?
  browser   String?
  os        String?
  userAgent String?
  metadata  String?  // JSON string
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
