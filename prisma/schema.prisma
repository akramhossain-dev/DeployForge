generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum AuthProvider {
  local
  github
  google
}

enum DeploymentStatus {
  PENDING
  BUILDING
  DEPLOYING
  CLONING
  UPLOADING
  EXTRACTING
  RUNNING
  PAUSED
  SUCCESS
  FAILED
  STOPPED
  DELETING
  ROLLED_BACK
  DELETED
}

enum DomainStatus {
  PENDING
  ACTIVE
  FAILED
  DELETED
}

enum SSLStatus {
  NONE
  ISSUED
  EXPIRED
  FAILED
}

enum DeploymentType {
  STATIC
  SERVER
  FULLSTACK
}

enum SourceType {
  github
  upload
}

enum TerminalSessionStatus {
  ACTIVE
  CLOSED
  FAILED
}

enum WebhookStatus {
  PENDING
  PROCESSED
  FAILED
}

enum VPSStatus {
  active
  inactive
  failed
}

enum VPSAuthType {
  key
  password
  ssh_key
}

enum SandboxStatus {
  approved
  warning
  rejected
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
}

model User {
  id                      String                   @id @default(uuid())
  email                   String?                  @unique
  username                String?                  @unique
  passwordHash            String?
  name                    String?
  avatarUrl               String?
  githubId                String?                  @unique
  githubUsername          String?
  githubAvatar            String?
  googleId                String?                  @unique
  googleEmail             String?
  googleAvatar            String?
  isVerified              Boolean                  @default(false)
  role                    Role                     @default(USER)
  status                  UserStatus               @default(ACTIVE)
  provider                String                   @default("email")
  authProvider            AuthProvider             @default(local)
  sessions                Session[]
  refreshTokenReplays     RefreshTokenReplay[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  notificationPreferences NotificationPreference?
  auditLogs               AuditLog[]
  vps                     VPS[]
  projects                Project[]
  githubAccount           GitHubAccount?
  terminalSessions        TerminalSession[]
  deployments             Deployment[]
  lastLoginAt             DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  @@index([role])
  @@index([status])
  @@index([provider])
  @@index([authProvider])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([lastLoginAt])
}

model AdminUser {
  id            String          @id @default(uuid())
  email         String          @unique
  name          String?
  passwordHash  String
  role          Role
  createdById   String?
  createdBy     AdminUser?      @relation("AdminCreatedUsers", fields: [createdById], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAdmins AdminUser[]     @relation("AdminCreatedUsers")
  sessions      AdminSession[]
  activities    AdminActivity[]
  lastLoginAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([role])
  @@index([createdById])
  @@index([createdAt])
  @@index([updatedAt])
}

model AdminSession {
  id        String    @id @default(uuid())
  adminId   String
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([adminId])
  @@index([expiresAt])
  @@index([createdAt])
}

model AdminActivity {
  id           String    @id @default(uuid())
  adminId      String
  admin        AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  action       String
  targetUserId String?
  targetRole   String?
  targetType   String?
  targetId     String?
  ipAddress    String?
  timestamp    DateTime  @default(now())
  createdAt    DateTime  @default(now())

  @@index([adminId])
  @@index([targetUserId])
  @@index([timestamp])
  @@index([createdAt])
}

model Session {
  id           String               @id @default(cuid())
  userId       String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  refreshToken String               @unique
  authProvider AuthProvider         @default(local)
  userAgent    String?
  device       String?
  browser      String?
  os           String?
  ipAddress    String?
  lastActivity DateTime             @default(now())
  expiresAt    DateTime
  createdAt    DateTime             @default(now())
  replayTokens RefreshTokenReplay[]

  @@index([userId])
  @@index([userId, lastActivity])
  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@index([createdAt])
}

model RefreshTokenReplay {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, expiresAt])
  @@index([sessionId])
  @@index([sessionId, expiresAt])
  @@index([expiresAt])
  @@index([createdAt])
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([email])
  @@index([email])
  @@index([expiresAt])
  @@index([createdAt])
}

model GitHubAccount {
  id           String       @id @default(uuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  githubId     String       @unique
  accessToken  String
  username     String
  email        String?
  avatarUrl    String?
  repositories Repository[]
  connectedAt  DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([userId])
  @@index([githubId])
  @@index([connectedAt])
  @@index([updatedAt])
}

model Repository {
  id              String        @id @default(uuid())
  githubAccountId String
  githubAccount   GitHubAccount @relation(fields: [githubAccountId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  repoId          String        @unique
  name            String
  fullName        String
  description     String?
  private         Boolean       @default(false)
  defaultBranch   String        @default("main")
  cloneUrl        String?
  webhookId       String?
  updatedAt       DateTime      @updatedAt
  createdAt       DateTime      @default(now())

  @@index([githubAccountId])
  @@index([githubAccountId, fullName])
  @@index([repoId])
  @@index([createdAt])
  @@index([updatedAt])
}

model TerminalSession {
  id        String                @id @default(uuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  vpsId     String
  vps       VPS                   @relation(fields: [vpsId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sessionId String                @unique
  status    TerminalSessionStatus @default(ACTIVE)
  logs      TerminalCommandLog[]
  startedAt DateTime              @default(now())
  endedAt   DateTime?

  @@index([userId])
  @@index([vpsId])
  @@index([sessionId])
  @@index([status])
  @@index([startedAt])
}

model TerminalCommandLog {
  id        String          @id @default(uuid())
  sessionId String
  session   TerminalSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  command   String?
  output    String?
  timestamp DateTime        @default(now())

  @@index([sessionId])
  @@index([timestamp])
}

model WebhookEvent {
  id        String        @id @default(uuid())
  repoId    String
  event     String
  payload   String
  status    WebhookStatus @default(PENDING)
  error     String?
  createdAt DateTime      @default(now())

  @@index([repoId])
  @@index([repoId, event])
  @@index([event])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

model VPS {
  id                  String            @id @default(uuid())
  userId              String
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  name                String
  ipAddress           String
  port                Int               @default(22)
  username            String            @default("root")
  authType            VPSAuthType       @default(key)
  encryptedPrivateKey String?
  encryptedPassword   String?
  status              VPSStatus         @default(inactive)
  lastCheckedAt       DateTime?
  deployments         Deployment[]
  healthRecords       VPSHealth[]
  terminalSessions    TerminalSession[]
  domains             Domain[]
  systemMetrics       SystemMetrics[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
}

model VPSHealth {
  id              String   @id @default(cuid())
  vpsId           String
  vps             VPS      @relation(fields: [vpsId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cpuUsage        Float
  memoryUsage     Float
  diskUsage       Float
  uptime          Int
  dockerInstalled Boolean
  nginxInstalled  Boolean
  checkedAt       DateTime @default(now())

  @@index([vpsId])
  @@index([checkedAt])
}

model Project {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  name          String
  repositoryUrl String
  branch        String       @default("main")
  framework     String?
  deployments   Deployment[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId])
  @@index([userId, repositoryUrl])
  @@index([createdAt])
  @@index([updatedAt])
}

model Deployment {
  id                String              @id @default(uuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  projectId         String
  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  vpsId             String
  vps               VPS                 @relation(fields: [vpsId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  name              String?
  status            DeploymentStatus    @default(PENDING)
  framework         String?
  type              DeploymentType      @default(SERVER)
  port              Int?
  buildCommand      String?
  startCommand      String?
  env               String?
  containerId       String?
  sourceType        SourceType          @default(github)
  repoUrl           String?
  branch            String?
  uploadPath        String?
  commitHash        String?
  commitMessage     String?
  lastStableVersion String?
  domain            String?
  hostType          String              @default("ip")
  mode              String              @default("production")
  deploymentLogs    DeploymentLog[]
  history           DeploymentHistory[]
  sandbox           DeploymentSandbox?
  domains           Domain[]
  jobs              DeploymentJob[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([userId, status, createdAt])
  @@index([projectId])
  @@index([projectId, status])
  @@index([vpsId])
  @@index([vpsId, status])
  @@index([sourceType])
  @@index([type])
  @@index([domain])
  @@index([hostType])
  @@index([mode])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
}

model DeploymentJob {
  id           String     @id @default(uuid())
  deploymentId String
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  status       JobStatus  @default(QUEUED)
  retryCount   Int        @default(0)
  lastError    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([deploymentId])
  @@index([deploymentId, status])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
}

model Domain {
  id              String       @id @default(uuid())
  deploymentId    String
  deployment      Deployment   @relation(fields: [deploymentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  vpsId           String
  vps             VPS          @relation(fields: [vpsId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  domainName      String       @unique
  status          DomainStatus @default(PENDING)
  sslStatus       SSLStatus    @default(NONE)
  nginxConfigPath String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([deploymentId])
  @@index([deploymentId, status])
  @@index([vpsId])
  @@index([vpsId, status])
  @@index([status])
  @@index([sslStatus])
  @@index([createdAt])
}

model DeploymentSandbox {
  id            String        @id @default(uuid())
  deploymentId  String        @unique
  deployment    Deployment    @relation(fields: [deploymentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  score         Int
  status        SandboxStatus
  issues        String[]
  estimatedCPU  Float
  estimatedRAM  Float
  estimatedDisk Float
  createdAt     DateTime      @default(now())

  @@index([deploymentId])
  @@index([deploymentId, status])
  @@index([status])
  @@index([createdAt])
}

model DeploymentHistory {
  id           String           @id @default(uuid())
  deploymentId String
  deployment   Deployment       @relation(fields: [deploymentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  version      String
  containerId  String?
  imageTag     String?
  status       DeploymentStatus
  env          String?
  createdAt    DateTime         @default(now())

  @@index([deploymentId])
  @@index([deploymentId, status])
  @@index([status])
  @@index([createdAt])
}

model SystemMetrics {
  id               String   @id @default(uuid())
  vpsId            String
  vps              VPS      @relation(fields: [vpsId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cpuUsage         Float
  memoryUsage      Float
  diskUsage        Float
  activeContainers Int
  timestamp        DateTime @default(now())

  @@index([vpsId])
  @@index([timestamp])
}

model DeploymentLog {
  id           String     @id @default(uuid())
  deploymentId String
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  type         String
  level        String     @default("info")
  message      String
  createdAt    DateTime   @default(now())

  @@index([deploymentId])
  @@index([deploymentId, createdAt])
  @@index([type])
  @@index([level])
  @@index([createdAt])
  @@index([level, createdAt])
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("new")
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@index([createdAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@index([createdAt])
}

model NotificationPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  deployNotifications Boolean  @default(true)
  buildNotifications  Boolean  @default(true)
  domainNotifications Boolean  @default(true)
  sslNotifications    Boolean  @default(true)
  securityAlerts      Boolean  @default(true)
  productUpdates      Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  action    String
  details   String
  ipAddress String?
  device    String?
  browser   String?
  os        String?
  userAgent String?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([action, createdAt])
  @@index([createdAt])
}
