# =============================================================================
# DeployForge — Production Environment Template
# =============================================================================
# Copy this file to .env, fill in ALL values, and NEVER commit the filled file.
# Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================

# --- Application ---
NODE_ENV="production"
PORT=3001
APP_URL="https://yourdomain.com"
API_URL="https://yourdomain.com"
LOG_LEVEL="warn"

# --- Frontend ---
NEXT_PUBLIC_API_URL="https://yourdomain.com"

# --- Database ---
POSTGRES_USER="deployforge"
POSTGRES_PASSWORD=""           # REQUIRED: strong random password
POSTGRES_DB="deployforge"
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public"

# --- Authentication ---
# min 64 hex chars — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=""                  # REQUIRED
ADMIN_SECRET=""                # REQUIRED
ADMIN_JWT_SECRET=""            # REQUIRED — must differ from JWT_SECRET

# --- Encryption ---
ENCRYPTION_KEY=""              # REQUIRED — 64 hex chars
MASTER_KEY=""                  # Optional — set to a DIFFERENT 64-hex string for key separation

# --- Redis ---
REDIS_ENABLED=true
REDIS_PASSWORD=""              # REQUIRED: set a strong password
REDIS_URL="redis://:${REDIS_PASSWORD}@redis:6379"

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=""            # REQUIRED
GITHUB_CLIENT_SECRET=""        # REQUIRED — rotate if ever exposed
GITHUB_CALLBACK_URL="https://yourdomain.com/auth/github/callback"
GITHUB_WEBHOOK_SECRET=""       # REQUIRED — 64 hex chars

# --- Google OAuth ---
GOOGLE_OAUTH_ENABLED=true
GOOGLE_CLIENT_ID=""            # REQUIRED if GOOGLE_OAUTH_ENABLED=true
GOOGLE_CLIENT_SECRET=""        # REQUIRED if GOOGLE_OAUTH_ENABLED=true
GOOGLE_CALLBACK_URL="https://yourdomain.com/auth/google/callback"

# --- SMTP ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""                   # REQUIRED
SMTP_PASS=""                   # REQUIRED — use an App Password, not your account password
# Optional: display name in From header. Falls back to SMTP_USER if not set.
SMTP_FROM="DeployForge <noreply@yourdomain.com>"

# --- Super Admin ---
SUPER_ADMIN_EMAIL=""           # REQUIRED
SUPER_ADMIN_PASSWORD=""        # REQUIRED — min 8 chars, use a strong password

# --- Security & Rate Limiting ---
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW="1 minute"
ADMIN_MAX_ATTEMPTS=5
ADMIN_LOCKOUT_TIME=900

# --- Metrics ---
# Protect /metrics with a Bearer token. Leave empty to disable protection (not recommended).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
METRICS_TOKEN=""               # REQUIRED for production

# --- Production TLS (Nginx + Certbot) ---
# Used by: docker compose --profile production up
DOMAIN="yourdomain.com"
CERTBOT_EMAIL="you@yourdomain.com"
