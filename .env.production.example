# Application
NODE_ENV="production"
PORT=4000
APP_URL="https://app.example.com"
API_URL="https://api.example.com"
LOG_LEVEL="info"

# Frontend
NEXT_PUBLIC_API_URL="https://api.example.com"

# Database
DATABASE_URL="postgresql://user:password@host:5432/deployforge?schema=public"

# Authentication
JWT_SECRET="replace_with_a_strong_random_jwt_secret"

# Admin Authentication
ADMIN_SECRET="replace_with_a_strong_admin_bootstrap_secret"
ADMIN_JWT_SECRET="replace_with_a_strong_random_admin_jwt_secret"

# GitHub OAuth
GITHUB_CLIENT_ID="your_github_oauth_client_id"
GITHUB_CLIENT_SECRET="your_github_oauth_client_secret"
GITHUB_CALLBACK_URL="https://api.example.com/auth/github/callback"
GITHUB_WEBHOOK_SECRET="replace_with_a_strong_random_webhook_secret"

# Google OAuth
GOOGLE_OAUTH_ENABLED=true
GOOGLE_CLIENT_ID="your_google_oauth_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_oauth_client_secret"
GOOGLE_CALLBACK_URL="https://api.example.com/auth/google/callback"

# SMTP
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER="smtp_username"
SMTP_PASS="smtp_password"

# Redis
REDIS_URL="redis://redis.example.com:6379"

# Encryption
ENCRYPTION_KEY="replace_with_64_hex_characters"
MASTER_KEY="replace_with_the_same_64_hex_characters_as_encryption_key"

# Deployment
# Reserved for future deployment provider configuration.

# Monitoring
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW="1 minute"

# Security
# Store production secrets in your platform secret manager, not in source control.
