{
    "compilerOptions": {
        "target": "ESNext",
        "module": "CommonJS",
        "moduleResolution": "node",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ],
            "@deployforge/database": [
                "../../packages/database/src"
            ],
            "@deployforge/security": [
                "../../packages/security/src"
            ],
            "@deployforge/shared": [
                "../../packages/shared/src"
            ],
            "@deployforge/mail": [
                "../../packages/mail/src"
            ],
            "@deployforge/vps": [
                "../../packages/vps/src"
            ]
        },
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": "./src"
    },
    "include": [
        "src/**/*"
    ]
}